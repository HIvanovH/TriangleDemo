<Window x:Class="TriangleDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TriangleDemo.Views"
        Title="Triangle Demo"
        Width="1000"
        Height="650"
        MinWidth="800"
        MinHeight="500"
        Background="#F3F4F6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <views:InputPanelView Grid.Column="0"
                      DataContext="{Binding Input}" />
        <views:RenderView Grid.Column="1" />
    </Grid>
</Window>
