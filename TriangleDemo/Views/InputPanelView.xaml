<UserControl x:Class="TriangleDemo.Views.InputPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TriangleDemo.Views"
             xmlns:vc="clr-namespace:TriangleDemo.Helpers.Converters"
             xmlns:controls ="clr-namespace:TriangleDemo.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="240">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="#FAFAFA"
            BorderBrush="#D1D5DB"
            BorderThickness="0,0,1,0"
            Padding="20">
        <DockPanel LastChildFill="True">

            <Border DockPanel.Dock="Bottom"
                Background="#FDEDED"
                BorderBrush="#F3CACA"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,16,0,0"
                Visibility="{Binding HasErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="18" Height="18"
                        CornerRadius="9"
                        Margin="0,0,8,0"
                        VerticalAlignment="Top">
                        <TextBlock Text="✕"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="#AB0909"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Cannot render"
                       FontWeight="SemiBold"
                       Foreground="#AB0909"/>
                        <TextBlock Text="Fix validation errors above"
                       Foreground="#AB0909"
                       FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel>
                <TextBlock Text="SIDES"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#666666"
                Margin="0,0,0,10"/>

                <controls:SideInputControl 
                    Label="a" Value="{Binding SideA}" 
                    Error="{Binding SideAError}" 
                    Validation.ErrorTemplate="{x:Null}"/>
                <controls:SideInputControl 
                    Label="b" Value="{Binding SideB}" 
                    Error="{Binding SideBError}" 
                    Validation.ErrorTemplate="{x:Null}"/>
                <controls:SideInputControl 
                    Label="c" Value="{Binding SideC}" 
                    Error="{Binding SideCError}" 
                    Validation.ErrorTemplate="{x:Null}"/>

                <controls:ColorSelector/>
                
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>