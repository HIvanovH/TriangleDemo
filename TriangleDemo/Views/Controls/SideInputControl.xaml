<UserControl x:Class="TriangleDemo.Views.Controls.SideInputControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vc="clr-namespace:TriangleDemo.Helpers.Converters">
    <UserControl.Resources>
        <vc:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,0,0,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding Label, ElementName=Root}"
                   FontSize="13" FontStyle="Italic"
                   VerticalAlignment="Center"/>

        <Border Grid.Column="1" BorderThickness="1" ClipToBounds="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Gray"/>
                    <Setter Property="CornerRadius" Value="6"/>
                    <Setter Property="Background"   Value="White"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Error, ElementName=Root, Converter={StaticResource NullToBoolConverter}}" Value="True">
                            <Setter Property="BorderBrush" Value="#EF4444"/>
                            <Setter Property="Background"  Value="#FEF2F2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBox Text="{Binding Value, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Background="Transparent" BorderThickness="0"
                     Padding="6,0" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="{Binding Error, ElementName=Root}"
                   Foreground="#AB0909" FontSize="12"
                   Height="13" Margin="0,2,0,5"/>
    </Grid>
</UserControl>
